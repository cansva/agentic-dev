{
  "name": "agentic-dev",
  "dockerFile": "../Dockerfile",
  "context": "..",
  "remoteEnv": {
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}",
    "OPENAI_API_KEY": "${localEnv:OPENAI_API_KEY}",
    "GH_TOKEN": "${localEnv:GH_TOKEN}"
  },
  "mounts": [
    "source=${localEnv:HOME}/.gitconfig,target=/home/node/.gitconfig,type=bind,readonly",
    "source=${localEnv:HOME}/.ssh,target=/home/node/.ssh,type=bind,readonly",
    "source=agentic-dev-claude-config,target=/home/node/.claude,type=volume",
    "source=agentic-dev-gh-config,target=/home/node/.config/gh,type=volume"
  ],
  "postCreateCommand": "mkdir -p /home/node/.claude && cp -n /opt/agentic-dev-settings.json /home/node/.claude/settings.json",
  "remoteUser": "node",
  "overrideCommand": true,
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "github.codespaces"
      ]
    }
  }
}
